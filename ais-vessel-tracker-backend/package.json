{
  "name": "ais-vessel-tracker-backend",
  "version": "1.0.0",
  "description": "AIS Vessel Tracking Backend - Real-time vessel position tracking API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "mock": "NODE_OPTIONS='--openssl-legacy-provider' ts-node-dev --respawn --transpile-only src/mock-feed.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "aisparser": "^0.1.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "ts-node": {
    "esm": false,
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
